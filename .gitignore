.venv/
venv/
__pycache__/
*.py[cod]
*.log
.idea/
.vscode/

# Секреты окружения (на сервере свой .env)
.env
.env.*
!.env.example

# Telegram: файлы сессий только на сервере / у разработчика локально
*.session
*.session-journal
sessions/*
!sessions/.gitkeep

# Реестр с api_id/api_hash — на сервере копия из шаблона accounts_registry.json.example
accounts_registry.json

# Состояние диалогов и sales-sync (на сервере)
data/*.json
!data/.gitkeep

# Фронтенды (если появятся отдельные сборки)
user/node_modules/
user/dist/
admin/node_modules/
admin/dist/

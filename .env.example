# Comet API (https://api.cometapi.com/console/token)
# Основное имя — как в GitHub Environment secret → на сервере COMET_API_KEY
COMET_API_KEY=

# Порт HTTP (только localhost, наружу — nginx)
FNR_HTTP_PORT=8765

# Bitrix24: входящий вебхук с правами CRM (лиды, сделки, конвертация, контакты).
# Укажите базовый URL …/rest/USER/TOKEN/ или полный к методу — см. app/bitrix.py (bitrix_webhook_base).
# Примеры:
#   BITRIX_INCOMING_WEBHOOK=https://YOUR.bitrix24.ru/rest/1/SECRET/
#   BITRIX_INCOMING_WEBHOOK=https://YOUR.bitrix24.ru/rest/1/SECRET/crm.lead.add.json
# Нужны как минимум: crm.lead.add, crm.lead.convert (или после ошибки — crm.deal.add), crm.lead.update,
# crm.deal.update, crm.timeline.comment.add, crm.contact.update, crm.lead.get.
# Стадии сделки для автоматического перевода ботом:
# BITRIX_DEAL_STAGE_WON=CLOSED_WON
# BITRIX_DEAL_STAGE_LOST=CLOSED_LOST
# Опционально: переопределение Bitrix user id по маршруту [[FNR_ROUTE:…]] в ответе бота (сделка).
# Если не задано — берётся тот же Bitrix user id, что в карточке сотрудника с этой ролью (как при автопередаче).
# BITRIX_ROUTE_MAP={"seller":12,"manager":7,"tech":19,"economist":23,"dispatcher":31}
# Алиас: BITRIX_WEBHOOK_URL (то же значение).
# После изменения .env перезапустите процесс API. Без вебхука лиды с сайта только в Telegram, в CRM не создаются.
BITRIX_INCOMING_WEBHOOK=

# Voximplant: сценарий шлёт POST на /voximplant/webhook (см. voximplant/scenario_inbound_test.js).
# Если задан — принимаются только запросы с X-Voximplant-Secret, Bearer или ?token=
# VOXIMPLANT_WEBHOOK_SECRET=

# Опционально (Comet): whisper по умолчанию whisper-1; vision — по умолчанию та же, что модель диалога (grok-4-1-fast-non-reasoning)
# COMET_WHISPER_MODEL=whisper-1
# COMET_VISION_MODEL=grok-4-1-fast-non-reasoning

# ═══════════════════════════════════════════════════════════════════════════════
# PolygraphAiSales — шаблон .env (копируйте в .env только на сервере / локально).
# В git коммитится только этот файл; реальные ключи и сессии — никогда в репозиторий.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Comet API (диалоги, при необходимости whisper / vision) ────────────────────
# https://api.cometapi.com/console/token
COMET_API_KEY=

# ── HTTP (только 127.0.0.1; наружу — nginx /fnr-api/) ─────────────────────────
FNR_HTTP_PORT=8765

# ── Bitrix24: обязательно на production ────────────────────────────────────────
# Входящий вебхук пользователя с правами CRM (Исходящий вебхук / Incoming webhook).
# Формат базы: https://<портал>.bitrix24.ru/rest/<user_id>/<token>/
# Можно указать с суффиксом метода (.json) — см. bitrix_webhook_base() в app/bitrix.py
#
# Алиас той же переменной: BITRIX_WEBHOOK_URL
#
# Чеклист прав вебхука (имена методов REST — для настройки в Bitrix):
#   • crm.lead.add          — заявка с сайта
#   • crm.lead.get          — чтение лида
#   • crm.lead.update       — поля лида, комментарии
#   • crm.lead.convert      — конвертация лида → сделка (основной путь)
#   • crm.deal.add          — резерв, если convert недоступен
#   • crm.deal.get          — чтение сделки
#   • crm.deal.update       — стадия, ответственный, комментарии в карточке
#   • crm.contact.update    — при необходимости
#   • crm.timeline.comment.add — лента сделки/лида
#
# После смены URL или прав — перезапуск: ./restart.sh
BITRIX_INCOMING_WEBHOOK=

# Символьные коды или ID стадий воронки сделки (значения из вашей CRM):
# BITRIX_DEAL_STAGE_WON=CLOSED_WON
# BITRIX_DEAL_STAGE_LOST=CLOSED_LOST

# JSON: явное сопоставление маршрута бота [[FNR_ROUTE:...]] → ASSIGNED_BY_ID в Bitrix.
# Если ключ не задан, берётся пользователь Bitrix из роли в синхронизации команды (fnr_sales_sync.json).
# BITRIX_ROUTE_MAP={"seller":12,"manager":7,"tech":19,"economist":23,"dispatcher":31}

# ── Voximplant (вебхук завершения звонка → журнал в админке) ──────────────────
# Задайте тот же секрет в сценарии (заголовок / Bearer / ?token=)
# VOXIMPLANT_WEBHOOK_SECRET=

# ── Comet: переопределение моделей (опционально) ──────────────────────────────
# COMET_WHISPER_MODEL=whisper-1
# COMET_VISION_MODEL=grok-4-1-fast-non-reasoning
